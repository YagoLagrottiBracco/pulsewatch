{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["gru1"],
  "crons": [
    {
      "path": "/api/cron/check-status",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/weekly-report",
      "schedule": "0 11 * * 1"
    },
    {
      "path": "/api/cron/weekly-insights",
      "schedule": "0 12 * * 1"
    }
  ]
}
